{
  "name": "foodwiser-be",
  "version": "1.0.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "db:push": "bunx drizzle-kit push",
    "db:generate": "bunx drizzle-kit generate",
    "db:seed": "bun run src/db/seeds/seedHalalData.ts",
    "db:studio": "bunx drizzle-kit studio",
    "db:drop": "bun run src/db/migrations/drop-tables.ts",
    "db:reset": "bun run db:drop && bun run db:push && bun run db:seed",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "drizzle-kit": "^0.31.9",
    "prettier": "^3.8.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "drizzle-orm": "^0.45.1",
    "groq-sdk": "^0.37.0",
    "hono": "^4.12.3",
    "hono-rate-limiter": "^0.5.3",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  }
}
